<?xml version='1.0'?>
<datamodel version="6.0"
     xmlns="http://www.tresos.de/_projects/DataModel2/14/root.xsd"
     xmlns:a="http://www.tresos.de/_projects/DataModel2/14/attribute.xsd"
     xmlns:v="http://www.tresos.de/_projects/DataModel2/06/schema.xsd"
     xmlns:d="http://www.tresos.de/_projects/DataModel2/06/data.xsd">

     <d:ctr type="AUTOSAR" factory="autosar"
          xmlns:ad="http://www.tresos.de/_projects/DataModel2/08/admindata.xsd"
          xmlns:cd="http://www.tresos.de/_projects/DataModel2/08/customdata.xsd"
          xmlns:f="http://www.tresos.de/_projects/DataModel2/14/formulaexpr.xsd"
          xmlns:icc="http://www.tresos.de/_projects/DataModel2/08/implconfigclass.xsd"
          xmlns:mt="http://www.tresos.de/_projects/DataModel2/11/multitest.xsd"
          xmlns:variant="http://www.tresos.de/_projects/DataModel2/11/variant.xsd">
          <d:lst type="TOP-LEVEL-PACKAGES">
               <d:ctr name="TI_AM263x" type="AR-PACKAGE">
                    <a:a name="UUID" value="ECUC:AUTOSAR" />
                    <d:lst type="ELEMENTS">
                         <d:chc name="Cdd_FsiTx" type="AR-ELEMENT" value="MODULE-DEF">
                              <v:ctr type="MODULE-DEF">
                                   <a:a name="ADMIN-DATA" type="ADMIN-DATA">
                                        <ad:ADMIN-DATA>
                                             <ad:DOC-REVISIONS>
                                                  <ad:DOC-REVISION>
                                                       <ad:REVISION-LABEL>4.3.1</ad:REVISION-LABEL>
                                                       <ad:ISSUED-BY>AUTOSAR</ad:ISSUED-BY>
                                                  </ad:DOC-REVISION>
                                             </ad:DOC-REVISIONS>
                                        </ad:ADMIN-DATA>
                                   </a:a>
                                   <a:a name="DESC" value="EN: Configuration of the Cdd Fsi Tx (Fast serial Interface -Transmitter) module." />
                                   <a:a name="LOWER-MULTIPLICITY" value="0" />
                                   <a:a name="POSTBUILDVARIANTSUPPORT" value="true" />
                                   <a:a name="RELEASE" value="asc:4.3.1" />
                                   <a:a name="UPPER-MULTIPLICITY" value="1" />
                                   <a:a name="UUID" value="ECUC:549d55dc-2095-47a5-a665-2d1414f9b5fb" />
                                   <v:var name="IMPLEMENTATION_CONFIG_VARIANT" type="ENUMERATION">
                                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                             <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                                             <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                        </a:a>
                                        <a:a name="LABEL" value="Config Variant" />
                                        <a:da name="DEFAULT" value="VariantPostBuild" />
                                        <a:da name="RANGE">
                                             <a:v>VariantPostBuild</a:v>
                                             <a:v>VariantPreCompile</a:v>
                                        </a:da>
                                   </v:var>
                                   <!--Design:
                              MCAL-  -->

                                   <v:ctr name="CddFsiTxConfigSet" type="IDENTIFIABLE">
                                        <a:a name="DESC" value="EN: This container contains the configuration parameters and sub containers of the AUTOSAR Cdd Fsi Tx module." />
                                        <a:a name="UUID" value="ECUC:fc6e2317-8c73-4b71-b09e-dfb54b76e50d" />
                                         <v:var name="CddFsiTxNotification" type="FUNCTION-NAME">
                                             <a:a name="DESC"
                                                  value="EN: Callback function for Transmission" />
                                             <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                                  type="IMPLEMENTATIONCONFIGCLASS">
                                                  <icc:v class="PostBuild">VariantPostBuild</icc:v>
                                                  <icc:v class="PreCompile">VariantPreCompile</icc:v>
                                             </a:a>
                                             <a:a name="OPTIONAL" value="false" />
                                             <a:a name="ORIGIN" value="Texas Instruments" />
                                             <a:a name="POSTBUILDVARIANTVALUE" value="true" />
                                             <a:a name="SCOPE" value="LOCAL" />
                                             <a:a name="SYMBOLICNAMEVALUE" value="false" />
                                             <a:a name="UUID"
                                                  value="ECUC:5a625bc4-91f4-4c9f-93db-a54f8e49f213" />
                                             <a:da name="ENABLE" type="XPath"
                                                  expr="as:modconf('Cdd_FsiTx')[1]/CddFsiTxGeneral/CddFsiTxNotifyCapability = 'true'" />
                                             <a:da name="DEFAULT" value="NULL_PTR" />
                                        </v:var>
                                        <v:var name="CddFsiTxOverRunNotification"
                                             type="FUNCTION-NAME">
                                             <a:a name="DESC"
                                                  value="EN: Callback function for Tx Buffer OverRun" />
                                             <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                                  type="IMPLEMENTATIONCONFIGCLASS">
                                                  <icc:v class="PostBuild">VariantPostBuild</icc:v>
                                                  <icc:v class="PreCompile">VariantPreCompile</icc:v>
                                             </a:a>
                                             <a:a name="OPTIONAL" value="false" />
                                             <a:a name="ORIGIN" value="Texas Instruments" />
                                             <a:a name="POSTBUILDVARIANTVALUE" value="true" />
                                             <a:a name="SCOPE" value="LOCAL" />
                                             <a:a name="SYMBOLICNAMEVALUE" value="false" />
                                             <a:a name="UUID"
                                                  value="ECUC:bed5cbf3-2ceb-4f33-a763-8d5b5aa752a5" />
                                             <a:da name="ENABLE" type="XPath"
                                                  expr="as:modconf('Cdd_FsiTx')[1]/CddFsiTxGeneral/CddFsiTxNotifyCapability = 'true'" />
                                             <a:da name="DEFAULT"
                                                  value="NULL_PTR" />
                                        </v:var>
                                        <v:var name="CddFsiTxUnderRunNotification"
                                             type="FUNCTION-NAME">
                                             <a:a name="DESC"
                                                  value="EN: Callback function for Tx Buffer UnderRun" />
                                             <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                                  type="IMPLEMENTATIONCONFIGCLASS">
                                                  <icc:v class="PostBuild">VariantPostBuild</icc:v>
                                                  <icc:v class="PreCompile">VariantPreCompile</icc:v>
                                             </a:a>
                                             <a:a name="OPTIONAL" value="false" />
                                             <a:a name="ORIGIN" value="Texas Instruments" />
                                             <a:a name="POSTBUILDVARIANTVALUE" value="true" />
                                             <a:a name="SCOPE" value="LOCAL" />
                                             <a:a name="SYMBOLICNAMEVALUE" value="false" />
                                             <a:a name="UUID"
                                                  value="ECUC:1ddc19de-2c53-40df-b58d-6aea8de93d54" />
                                             <a:da name="ENABLE" type="XPath"
                                                  expr="as:modconf('Cdd_FsiTx')[1]/CddFsiTxGeneral/CddFsiTxNotifyCapability = 'true'" />
                                             <a:da name="DEFAULT"
                                                  value="NULL_PTR" />
                                        </v:var>
                                        <v:lst name="CddFsiTxHwUnit" type="MAP">
                                             <a:da name="MIN" value="1" />
                                             <a:da name="MAX" type="XPath" expr="num:i(node:value(as:modconf('Cdd_FsiTx')[1]/CddFsiTxGeneral/CddFsiTxMaxHwUnitCount))"/>
                                             <v:ctr name="CddFsiTxHwUnit" type="IDENTIFIABLE">
                                                  <a:a name="DESC" value="EN: This container contains the Driver configuration (parameters) depending on which FSI Hw unit is get configured" />
                                                  <a:a name="UUID" value="ECUC:a9e23023-9210-4150-9e32-c3271d669b0f" />

                                                  <v:var name="CddFsiTxHwUnitId" type="ENUMERATION">
                                                       <a:a name="DESC" value="EN: Description: Numeric ID of the HW Unit. This symbolic name allows accessing Fsi Hw Unit data. Enumeration literals are defined vendor specific.
                                                       Number of instances can vary depending on SOC variant.Corresponding error checks are added in template files" />
                                                       <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                            <icc:v vclass="PostBuild">
                                                                 VariantPostBuild</icc:v>
                                                            <icc:v vclass="PreCompile">
                                                                 VariantPreCompile</icc:v>
                                                       </a:a>
                                                       <a:a name="ORIGIN" value="Texas Instruments" />
                                                       <a:a name="POSTBUILDVARIANTVALUE" value="true" />
                                                       <a:a name="SCOPE" value="LOCAL" />
                                                       <a:a name="SYMBOLICNAMEVALUE" value="false" />
                                                       <a:a name="UUID" value="ECUC:3b1f9d44-1cf1-457b-ad33-bd86ab60ebf6" />
                                                       <a:da name="RANGE">
                                                            <a:v>CDD_FSI_TX_HWUNIT_0</a:v>
                                                            <a:v>CDD_FSI_TX_HWUNIT_1</a:v>
                                                            <a:v>CDD_FSI_TX_HWUNIT_2</a:v>
                                                            <a:v>CDD_FSI_TX_HWUNIT_3</a:v>
                                                       </a:da>
                                                       <a:da name="DEFAULT" value="CDD_FSI_TX_HWUNIT_0" />
                                                  </v:var>

                                                  <v:var name="CddFsiTxPrescale" type="ENUMERATION">
                                                       <a:a name="DESC" value="EN:Selects the Prescale value ." />
                                                       <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                            <icc:v vclass="PostBuild">
                                                                 VariantPostBuild</icc:v>
                                                            <icc:v vclass="PreCompile">
                                                                 VariantPreCompile</icc:v>
                                                       </a:a>
                                                       <a:a name="ORIGIN" value="Texas Instruments" />
                                                       <a:a name="POSTBUILDVARIANTVALUE" value="true" />
                                                       <a:a name="SCOPE" value="LOCAL" />
                                                       <a:a name="SYMBOLICNAMEVALUE" value="false" />
                                                       <a:a name="UUID" value="ECUC:1fb3e387-c03a-4a29-35d2-f8d71778a6fc" />
                                                       <a:da name="RANGE">
                                                            <a:v>CDD_FSI_TX_CLK_DIV_1</a:v>
                                                            <a:v>CDD_FSI_TX_CLK_DIV_2</a:v>
                                                            <a:v>CDD_FSI_TX_CLK_DIV_3</a:v>
                                                            <a:v>CDD_FSI_TX_CLK_DIV_4</a:v>
                                                            <a:v>CDD_FSI_TX_CLK_DIV_5</a:v>
                                                            <a:v>CDD_FSI_TX_CLK_DIV_10</a:v>
                                                            <a:v>CDD_FSI_TX_CLK_DIV_20</a:v>
                                                       </a:da>
                                                       <a:a name="DEFAULT" value="CDD_FSI_TX_CLK_DIV_2" />
                                                  </v:var>
                                                  <!--Design:
                                                   MCAL- -->
                                                  <v:var name="CddFsiTxPingTimerTimeout" type="INTEGER">
                                                       <a:a name="DESC" value="EN: Timeout value for CddFsiTx Ping Timer." />
                                                       <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                            <icc:v vclass="PostBuild">
                                                                 VariantPostBuild</icc:v>
                                                            <icc:v vclass="PreCompile">
                                                                 VariantPreCompile</icc:v>
                                                       </a:a>
                                                       <a:a name="OPTIONAL" value="true" />
                                                       <a:a name="ORIGIN" value="Texas Instruments" />
                                                       <a:a name="POSTBUILDVARIANTMULTIPLICITY" value="true" />
                                                       <a:a name="POSTBUILDVARIANTVALUE" value="true" />
                                                       <a:a name="SCOPE" value="LOCAL" />
                                                       <a:a name="SYMBOLICNAMEVALUE" value="false" />
                                                       <a:a name="UUID" value="ECUC:08931375-93ee-47e4-9c79-d1b70bfe260e" />
                                                       <a:da name="DEFAULT" value="20000" />
                                                       <a:da name="INVALID" type="Range">
                                                            <a:tst expr="&lt;=4294967295" />
                                                            <a:tst expr="&gt;=0" />
                                                       </a:da>
                                                  </v:var>

                                                  <!--Design:
                                                                 MCAL- -->
                                                  <v:var name="CddFsiTxTriggerSrc" type="ENUMERATION">
                                                       <a:a name="DESC" value="EN: Type of source event that starts a transmission." />
                                                       <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                            <icc:v vclass="PostBuild">
                                                                 VariantPostBuild</icc:v>
                                                            <icc:v vclass="PreCompile">
                                                                 VariantPreCompile</icc:v>
                                                       </a:a>
                                                       <a:a name="ORIGIN" value="Texas Instruments" />
                                                       <a:a name="POSTBUILDVARIANTVALUE" value="true" />
                                                       <a:a name="SCOPE" value="LOCAL" />
                                                       <a:a name="SYMBOLICNAMEVALUE" value="false" />
                                                       <a:a name="UUID" value="ECUC:1fb3e387-c03a-4a29-a5d2-f8d71778a6fc" />
                                                       <a:da name="RANGE">
                                                            <a:v>CDD_FSI_TX_TRIGG_SRC_SW</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGG_SRC_HW</a:v>
                                                       </a:da>
                                                       <a:da name="DEFAULT" value="CDD_FSI_TX_TRIGG_SRC_SW" />
                                                  </v:var>
                                                  <!--Design:
                                                                 MCAL- -->
                                                  <v:var name="CddFsiTxTransmissionMethod" type="ENUMERATION">
                                                       <a:a name="DESC" value="EN: Selects the method of frame transmission." />
                                                       <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                            <icc:v vclass="PostBuild">
                                                                 VariantPostBuild</icc:v>
                                                            <icc:v vclass="PreCompile">
                                                                 VariantPreCompile</icc:v>
                                                       </a:a>
                                                       <a:a name="OPTIONAL" value="true" />
                                                       <a:a name="ORIGIN" value="Texas Instruments" />
                                                       <a:a name="POSTBUILDVARIANTMULTIPLICITY" value="true" />
                                                       <a:a name="POSTBUILDVARIANTVALUE" value="true" />
                                                       <a:a name="SCOPE" value="LOCAL" />
                                                       <a:a name="SYMBOLICNAMEVALUE" value="false" />
                                                       <a:a name="UUID" value="ECUC:b80e962e-bef4-4736-9cd1-94e717677ddd" />
                                                       <a:da name="ENABLE" value="true" />
                                                       <a:da name="RANGE">
                                                            <a:v>CDD_FSI_TX_INTERRUPT_MODE</a:v>
                                                            <a:v>CDD_FSI_TX_POLLING_MODE</a:v>
                                                            <a:v>CDD_FSI_TX_DMA_MODE</a:v>
                                                       </a:da>
                                                       <a:da name="DEFAULT" value="CDD_FSI_TX_INTERRUPT_MODE" />
                                                  </v:var>
                                                  <!--Design:
                                                                 MCAL- -->
                                                  <v:var name="CddFsiTxExtHwTrigSrc" type="ENUMERATION">
                                                       <a:a name="DESC" value="EN: Configure the external trigger source for data frame and data frame " />
                                                       <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                            <icc:v vclass="PostBuild">
                                                                 VariantPostBuild</icc:v>
                                                            <icc:v vclass="PreCompile">
                                                                 VariantPreCompile</icc:v>
                                                       </a:a>
                                                       <a:a name="ORIGIN" value="Texas Instruments" />
                                                       <a:a name="POSTBUILDVARIANTVALUE" value="true" />
                                                       <a:a name="SCOPE" value="LOCAL" />
                                                       <a:a name="SYMBOLICNAMEVALUE" value="false" />
                                                       <a:a name="UUID" value="ECUC:ac85f589-5cf6-43f3-a6a7-d824eed384518" />
                                                       <a:da name="ENABLE" type="XPath"
                                                            expr="as:modconf('Cdd_FsiTx')[1]/CddFsiTxGeneral/CddFsiTxExtTriggerEnable = 'true'" />
                                                       <a:da name="RANGE">
                                                            <a:v>
                                                                 CDD_FSI_TX_TRIGGER_FSI_RX_PING_FRAME_TAG_MATCH</a:v>
                                                            <a:v>
                                                                 CDD_FSI_TX_TRIGGER_FSI_RX_ERROR_FRAME_TAG_MATCH</a:v>
                                                            <a:v>
                                                                 CDD_FSI_TX_TRIGGER_FSI_RX_DATA_FRAME_TAG_MATCH</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_FSI_RX_TRIG0</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_FSI_RX_TRIG1</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_FSI_RX_TRIG2</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_FSI_RX_TRIG3</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM0_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM1_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM2_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM3_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM4_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM5_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM6_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM7_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM8_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM9_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM10_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM11_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM12_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM13_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM14_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM15_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM16_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM17_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM18_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM19_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM20_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM21_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM22_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM23_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_ICSM_PORT0_16</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_ICSM_PORT0_17</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_ICSM_PORT0_18</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_ICSM_PORT0_19</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_ICSM_PORT1_16</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_ICSM_PORT1_17</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_ICSM_PORT1_18</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_ICSM_PORT1_19</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_OUTPUTXBAR_OUT0</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_OUTPUTXBAR_OUT1</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_OUTPUTXBAR_OUT2</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_OUTPUTXBAR_OUT3</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_OUTPUTXBAR_OUT4</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_OUTPUTXBAR_OUT5</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_OUTPUTXBAR_OUT6</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_OUTPUTXBAR_OUT7</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_OUTPUTXBAR_OUT8</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_OUTPUTXBAR_OUT9</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_OUTPUTXBAR_OUT10</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_OUTPUTXBAR_OUT11</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_OUTPUTXBAR_OUT12</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_OUTPUTXBAR_OUT13</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_OUTPUTXBAR_OUT14</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_OUTPUTXBAR_OUT15</a:v>
                                                       </a:da>
                                                       <a:da name="DEFAULT" value="CDD_FSI_TX_TRIGGER_FSI_RX_TRIG0" />
                                                  </v:var>
                                                  <!--Design:
                                                                 MCAL- -->
                                                  <v:var name="CddFsiTxExtPingTrigSrc" type="ENUMERATION">
                                                       <a:a name="DESC" value="EN: Configure the external trigger source for ping frame and data frame " />
                                                       <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                            <icc:v vclass="PostBuild">
                                                                 VariantPostBuild</icc:v>
                                                            <icc:v vclass="PreCompile">
                                                                 VariantPreCompile</icc:v>
                                                       </a:a>
                                                       <a:a name="ORIGIN" value="Texas Instruments" />
                                                       <a:a name="POSTBUILDVARIANTVALUE" value="true" />
                                                       <a:a name="SCOPE" value="LOCAL" />
                                                       <a:a name="SYMBOLICNAMEVALUE" value="false" />
                                                       <a:a name="UUID" value="ECUC:5bd20f5d-b956-4c23-92c4-d187aa9edc11" />
                                                       <a:da name="ENABLE" type="XPath"
                                                            expr="as:modconf('Cdd_FsiTx')[1]/CddFsiTxGeneral/CddFsiTxExtTriggerEnable = 'true'" />
                                                       <a:da name="RANGE">
                                                            <a:v>
                                                                 CDD_FSI_TX_TRIGGER_FSI_RX_PING_FRAME_TAG_MATCH</a:v>
                                                            <a:v>
                                                                 CDD_FSI_TX_TRIGGER_FSI_RX_ERROR_FRAME_TAG_MATCH</a:v>
                                                            <a:v>
                                                                 CDD_FSI_TX_TRIGGER_FSI_RX_DATA_FRAME_TAG_MATCH</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_FSI_RX_TRIG0</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_FSI_RX_TRIG1</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_FSI_RX_TRIG2</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_FSI_RX_TRIG3</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM0_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM1_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM2_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM3_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM4_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM5_SOCB</a:v>
                                                            <a:v>CDD_FSI_TX_TRIGGER_EPWM6_SOCB</a:v>
