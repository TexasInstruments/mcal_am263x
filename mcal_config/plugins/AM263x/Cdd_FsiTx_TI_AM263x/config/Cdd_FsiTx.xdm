                                             value="ASPathDataOfSchema:/AUTOSAR/EcucDefs/Os/OsCounter"/>
                                         </v:ref>

                                         <!--Design:  -->
                                         <v:var name="CddFsiTxDefaultOSCounterId" type="INTEGER">
                                           <a:a name="DESC" value="EN: Default Os Counter Id if node reference to OsCounter ref CddFsiTxOsCounterRef is not set"/>
