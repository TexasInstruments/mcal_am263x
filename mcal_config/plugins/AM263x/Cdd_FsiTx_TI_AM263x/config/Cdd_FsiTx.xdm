                                             <a:da name="DEFAULT" value="false" />
                                        </v:var>
                                        <v:var name="CddFsiTxMaxDmaChannelId" type="INTEGER">
                                             <a:a name="DESC" value="EN: Number of actual DMA channels. This is of type published information and not editable" />
                                             <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                  <icc:v class="PublishedInformation">
